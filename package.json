{
  "name": "@travjek/apig",
  "version": "0.8.0",
  "type": "module",
  "description": "OpenAPI code generator for TypeScript with a plugin system — generates types, SDK, Zod/Valibot/Yup schemas, TanStack Query / SWR hooks, React Hook Form resolvers, Faker factories and MSW handlers",
  "keywords": [
    "openapi",
    "openapi-generator",
    "codegen",
    "code-generator",
    "typescript",
    "typescript-generator",
    "api-client",
    "api-generator",
    "sdk",
    "sdk-generator",
    "zod",
    "valibot",
    "yup",
    "schema-validation",
    "tanstack-query",
    "react-query",
    "swr",
    "react-hook-form",
    "rhf",
    "msw",
    "mock-service-worker",
    "faker",
    "swagger",
    "swagger-codegen",
    "openapi3",
    "rest-api",
    "cli"
  ],
  "readme": "README.npm.md",
  "author": "danilapyzhikov",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/elPyzi/apig"
  },
  "bin": {
    "apig": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "import": "./dist/client/index.js",
      "types": "./dist/client/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.npm.md",
    "skills",
    ".claude-plugin"
  ],
  "scripts": {
    "build": "bun build src/cli.ts src/index.ts src/client/index.ts --outdir dist --target node --minify --external jiti && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "dev": "bun src/cli.ts",
    "generate": "bun src/cli.ts generate",
    "test": "bun test",
    "prepublish": "bun run build",
    "prepare": "husky"
  },
  "dependencies": {
    "@inquirer/prompts": "8.5.2",
    "@scalar/openapi-parser": "^0.28.8",
    "@scalar/openapi-upgrader": "^0.2.9",
    "commander": "15.0.0",
    "jiti": "2.7.0",
    "openapi-types": "12.1.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@faker-js/faker": "10.4.0",
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "tsc-alias": "1.8.17",
    "typescript": "5.8.3"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0",
    "@tanstack/react-query": ">=5.0.0",
    "swr": ">=2.0.0",
    "zod": ">=3.0.0",
    "valibot": ">=1.0.0",
    "yup": ">=1.0.0",
    "msw": ">=2.0.0",
    "@hookform/resolvers": ">=3.0.0",
    "@faker-js/faker": ">=9.0.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": true
    },
    "swr": {
      "optional": true
    },
    "zod": {
      "optional": true
    },
    "valibot": {
      "optional": true
    },
    "yup": {
      "optional": true
    },
    "msw": {
      "optional": true
    },
    "@hookform/resolvers": {
      "optional": true
    },
    "@faker-js/faker": {
      "optional": true
    }
  }
}
