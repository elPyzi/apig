{
  "name": "@travjek/apig",
  "version": "0.1.0",
  "type": "module",
  "description": "OpenAPI code generator for TypeScript",
  "keywords": [
    "openapi",
    "codegen",
    "typescript",
    "tanstack-query",
    "zod",
    "msw",
    "faker"
  ],
  "author": "danilapyzhikov",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/travjek/apig"
  },
  "bin": {
    "apig": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "import": "./dist/client/index.js",
      "types": "./dist/client/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "readme"
  ],
  "scripts": {
    "build": "bun build src/cli.ts src/index.ts src/client/index.ts --outdir dist --target node --minify --external jiti && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "dev": "bun src/cli.ts",
    "generate": "bun src/cli.ts generate",
    "test": "bun test",
    "prepublish": "bun run build"
  },
  "dependencies": {
    "@inquirer/prompts": "8.5.2",
    "@scalar/openapi-parser": "^0.28.8",
    "@scalar/openapi-upgrader": "^0.2.9",
    "commander": "15.0.0",
    "jiti": "2.7.0",
    "openapi-types": "12.1.3"
  },
  "devDependencies": {
    "@faker-js/faker": "10.4.0",
    "@types/bun": "latest",
    "tsc-alias": "1.8.17",
    "typescript": "5.8.3"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0",
    "@tanstack/react-query": ">=5.0.0",
    "swr": ">=2.0.0",
    "zod": ">=3.0.0",
    "valibot": ">=1.0.0",
    "yup": ">=1.0.0",
    "msw": ">=2.0.0",
    "@hookform/resolvers": ">=3.0.0",
    "@faker-js/faker": ">=9.0.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": true
    },
    "swr": {
      "optional": true
    },
    "zod": {
      "optional": true
    },
    "valibot": {
      "optional": true
    },
    "yup": {
      "optional": true
    },
    "msw": {
      "optional": true
    },
    "@hookform/resolvers": {
      "optional": true
    },
    "@faker-js/faker": {
      "optional": true
    }
  }
}
